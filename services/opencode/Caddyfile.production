media.crosslinecscatest.com {
	handle_path /downloads/* {
		root * /var/crossline-media/downloads
		header Access-Control-Allow-Origin "https://exam.crosslinecscatest.com"
		header Access-Control-Allow-Methods "GET,HEAD,OPTIONS"
		header Access-Control-Allow-Headers "content-type,range"
		file_server
	}

	handle_path /updates/* {
		root * /var/crossline-media/downloads
		header Access-Control-Allow-Origin "https://exam.crosslinecscatest.com"
		header Access-Control-Allow-Methods "GET,HEAD,OPTIONS"
		header Access-Control-Allow-Headers "content-type,range"
		file_server
	}

	handle_path /admin-ai/* {
		reverse_proxy 127.0.0.1:8090
	}

	reverse_proxy 127.0.0.1:8080
}
