{
  "name": "csca-practice-client",
  "version": "0.1.60",
  "description": "A Windows-ready CSCA mock exam client with dual-camera practice checks.",
  "author": "Crossline Education",
  "main": "electron/main.js",
  "scripts": {
    "postinstall": "install-electron --no",
    "start": "electron . --windowed",
    "start:kiosk": "electron .",
    "serve": "python3 -m http.server 4173",
    "test": "npm --prefix media-server test && node scripts/verify-migrations.mjs && node tests/source-import.js && node tests/update-helper.js && node tests/github-updater.js && node tests/content-protection.js && node tests/api-token-storage.mjs && node tests/plans.mjs && node tests/exam-attempts.mjs && node tests/result-email.mjs && node tests/transactional-email.mjs && node tests/bug-reports.mjs && node tests/v2-auth.mjs && node tests/launch-security.mjs && node tests/smoke.js",
    "test:production": "node scripts/verify-production-backend.mjs",
    "test:migrations": "node scripts/verify-migrations.mjs",
    "stress:api": "node scripts/stress-test-worker.mjs",
    "capture:equipment": "electron scripts/capture-equipment-check.js",
    "worker:dev": "wrangler dev --config worker/wrangler.toml",
    "worker:migrate": "wrangler d1 execute crossline-mocks --remote --config worker/wrangler.toml --file worker/schema.sql",
    "worker:migrate:0007": "wrangler d1 execute crossline-mocks --remote --config worker/wrangler.toml --file worker/migrations/0007_profiles_notifications_topics.sql",
    "worker:migrate:0008": "wrangler d1 execute crossline-mocks --remote --config worker/wrangler.toml --file worker/migrations/0008_analytics_scores.sql",
    "worker:migrate:0009": "wrangler d1 execute crossline-mocks --remote --config worker/wrangler.toml --file worker/migrations/0009_notification_kind.sql",
    "worker:migrate:0012": "wrangler d1 execute crossline-mocks --remote --config worker/wrangler.toml --file worker/migrations/0012_all_exams_free.sql",
    "worker:migrate:0013": "wrangler d1 execute crossline-mocks --remote --config worker/wrangler.toml --file worker/migrations/0013_exam_subjects_and_targeted_notifications.sql",
    "worker:migrate:0014": "wrangler d1 execute crossline-mocks --remote --config worker/wrangler.toml --file worker/migrations/0014_admin_roles_and_mfa.sql",
    "worker:migrate:0015": "wrangler d1 execute crossline-mocks --remote --config worker/wrangler.toml --file worker/migrations/0015_notification_archives.sql",
    "worker:migrate:0016": "wrangler d1 execute crossline-mocks --remote --config worker/wrangler.toml --file worker/migrations/0016_correct_january_physics_answers.sql",
    "worker:migrate:0017": "wrangler d1 execute crossline-mocks --remote --config worker/wrangler.toml --file worker/migrations/0017_style_january_physics_explanations.sql",
    "worker:migrate:0020": "wrangler d1 execute crossline-mocks --remote --config worker/wrangler.toml --file worker/migrations/0020_student_access_plans.sql",
    "worker:migrate:0021": "wrangler d1 execute crossline-mocks --remote --config worker/wrangler.toml --file worker/migrations/0021_free_sample_and_attempt_limit.sql",
    "worker:migrate:0022": "wrangler d1 execute crossline-mocks --remote --config worker/wrangler.toml --file worker/migrations/0022_bug_reports.sql",
    "worker:seed": "wrangler d1 execute crossline-mocks --remote --config worker/wrangler.toml --file worker/seed.sql",
    "worker:migrate:local": "wrangler d1 execute crossline-mocks --local --config worker/wrangler.toml --file worker/schema.sql",
    "worker:seed:local": "wrangler d1 execute crossline-mocks --local --config worker/wrangler.toml --file worker/seed.sql",
    "worker:deploy": "wrangler deploy --config worker/wrangler.toml",
    "prepare:win-native": "node scripts/prepare-win-native.mjs",
    "configure:github": "node scripts/configure-github-repository.mjs",
    "dist:win": "npm run prepare:win-native && electron-builder --win nsis --x64 --publish never && node scripts/build-update-patch.mjs",
    "release:github": "npm run prepare:win-native && electron-builder --win nsis --x64 --publish always",
    "v3": "vite --config src/v3/vite.config.mjs"
  },
  "build": {
    "appId": "com.crossline.csca.practice",
    "productName": "Crossline CSCA Practice Client",
    "files": [
      "build/icon.png",
      "build/icon.ico",
      "electron/**/*",
      "src/**/*",
      "!src/demos/**/*",
      "!src/v2/**/*",
      "!src/v3/**/*",
      "!src/assets/landing/hero-exam-desk.png",
      "!src/assets/landing/hero-dual-camera.png",
      "!src/assets/dashboard/challenge-banner.png",
      "!src/assets/landing/product/equipment-check.png",
      "!src/assets/landing/dual-camera-exam-clean.png",
      "!src/assets/landing/dual-camera-exam-math.png",
      "!src/assets/landing/setup-dual-camera.jpg",
      "!src/assets/landing/hero-exam-desk.jpg",
      "!src/assets/auth/login-books.png",
      "!src/assets/auth/login-room.png",
      "!src/assets/crosslinelogo.png",
      "!src/assets/crosslinelogo.jpg",
      "!src/assets/crosslinelogo-clean.png",
      "!src/assets/fonts/Kalam-Bold.woff2",
      "!src/assets/fonts/Kalam-Regular.woff2",
      "!src/assets/fonts/GloriaHallelujah.woff2",
      "!src/assets/fonts/PatrickHand.woff2",
      "!src/assets/fonts/inter/*.ttf",
      "!src/assets/fonts/playfair/*.ttf",
      "!src/assets/fonts/montserrat/*.ttf",
      "README.md"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "win": {
      "requestedExecutionLevel": "asInvoker",
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "artifactName": "Crossline-CSCA-Practice-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": false,
      "menuCategory": "Crossline Education",
      "shortcutName": "Crossline CSCA Practice",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "runAfterFinish": true,
      "include": "build/installer.nsh",
      "warningsAsErrors": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "arijitcrossline-hue",
        "repo": "crossline-csca-practice-client",
        "releaseType": "release",
        "vPrefixedTagName": false
      }
    ]
  },
  "dependencies": {
    "adm-zip": "^0.6.0",
    "electron-updater": "^6.8.9",
    "marked": "^16.4.2",
    "node-html-markdown": "^1.3.0",
    "node-html-parser": "^7.0.1",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@astryxdesign/cli": "^0.1.7",
    "@astryxdesign/core": "^0.1.7",
    "@astryxdesign/theme-neutral": "^0.1.7",
    "@stylexjs/stylex": "^0.19.0",
    "@vitejs/plugin-react": "^6.0.4",
    "electron": "^42.3.0",
    "electron-builder": "^26.0.12",
    "jsdom": "^29.1.1",
    "mathjax": "^3.2.2",
    "vite": "^8.1.5",
    "wrangler": "^4.50.0"
  },
  "overrides": {
    "sharp": "^0.35.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/arijitcrossline-hue/crossline-csca-practice-client.git"
  }
}
